generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id              String   @id @default(cuid())
  name            String
  email           String   @unique
  passwordHash    String
  plan            String   @default("FREE")
  apiKeyAnthropic String?
  apiKeyOpenAI    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  agents    Agent[]
  instances WhatsAppInstance[]
}

// Removendo Enums para compatibilidade com SQLite
// enum Plan { ... }

model Agent {
  id            String      @id @default(cuid())
  userId        String
  name          String
  systemPrompt  String
  model         String      @default("CLAUDE_SONNET")
  tone          String      @default("FRIENDLY")
  language      String      @default("pt-BR")
  memoryEnabled Boolean     @default(true)
  memoryWindow  Int         @default(20)
  status        String      @default("ACTIVE")
  instanceId    String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  instance      WhatsAppInstance? @relation(fields: [instanceId], references: [id])
  conversations Conversation[]
}

// Removendo Enums para compatibilidade com SQLite
// enum AIModel { ... }
// enum Tone { ... }
// enum AgentStatus { ... }

model WhatsAppInstance {
  id           String         @id @default(cuid())
  userId       String
  instanceName String         @unique
  phoneNumber  String?
  status       String @default("DISCONNECTED")
  evolutionUrl String
  evolutionKey String
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  agents Agent[]
}

// enum InstanceStatus { ... }

model Conversation {
  id           String             @id @default(cuid())
  agentId      String
  contactName  String?
  contactPhone String
  status       String @default("ACTIVE")
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  agent    Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  messages Message[]

  @@unique([agentId, contactPhone])
}

// enum ConversationStatus { ... }

model Message {
  id             String      @id @default(cuid())
  conversationId String
  role           String
  content        String
  tokenCount     Int?
  processedAt    DateTime?
  createdAt      DateTime    @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

