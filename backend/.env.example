# ============================================
# AgendaFácil - Variáveis de Ambiente
# Renomeie este arquivo para .env e configure!
# ============================================

# Banco de Dados (PostgreSQL 17)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=agendafacil
DB_USER=postgres
DB_PASS=SUA_SENHA_FORTE_AQUI

# JWT - TROQUE POR UMA CHAVE ALEATÓRIA LONGA!
JWT_SECRET=GERE_UMA_CHAVE_LONGA_ALEATORIA_AQUI_MINIMO_64_CHARS

# Servidor
PORT=3000
NODE_ENV=production

# CORS - domínios permitidos (separe com vírgula)
ALLOWED_ORIGINS=https://seudominio.com.br,http://localhost:3000
